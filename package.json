{
  "name": "carter-s-care-platform",
  "version": "1.0.0",
  "description": "Professional care worker management platform",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
