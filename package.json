    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "lovable-tagger": "^1.1.13",
    "mongodb": "^7.1.1",
    "uuid": "^13.0.0",
    "vite": "^8.0.2",
    "zod": "^4.3.6"
  }
}
